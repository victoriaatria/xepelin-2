# Blog base (no trailing slash)
BLOG_BASE_URL=https://url.com/blog

# Public Sanity read API (used when the category HTML has no article links)
SANITY_PROJECT_ID=4n68r2aa
SANITY_DATASET=production

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your_project_id",...}
SPREADSHEET_ID=your_spreadsheet_id

# Webhook payload
CONTACT_EMAIL=your-email@gmail.com

# Optional override (default: https://www.googleapis.com/auth/spreadsheets)
# GOOGLE_SHEETS_SCOPES=https://www.googleapis.com/auth/spreadsheets

# Optional: limit posts for local testing
# SCRAPE_MAX_POSTS=5
